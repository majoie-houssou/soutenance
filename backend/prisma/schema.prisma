generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model abonnes_sms {
  id              Int       @id @default(autoincrement())
  telephone       String    @unique @db.VarChar(20)
  nom             String?   @db.VarChar(100)
  departement     String?   @db.VarChar(50)
  commune         String?   @db.VarChar(50)
  actif           Boolean?  @default(true)
  date_abonnement DateTime? @default(now()) @db.Timestamp(6)

  @@index([telephone], map: "idx_abonnes_sms_telephone")
}

model abonnes_email {
  id              Int       @id @default(autoincrement())
  email           String    @unique @db.VarChar(100)
  nom             String?   @db.VarChar(100)
  departement     String?   @db.VarChar(50)
  commune         String?   @db.VarChar(50)
  telephone       String?   @db.VarChar(20)
  actif           Boolean?  @default(true)
  date_abonnement DateTime? @default(now()) @db.Timestamp(6)

}

model historiques_emails {
  id            Int       @id @default(autoincrement())
  zone          String?   @db.VarChar(50)
  message       String
  niveau_alerte String?   @db.VarChar(30)
  destinataires Int?
  succes        Int?
  echec         Int?
  statut        String?   @default("envoye") @db.VarChar(20)
  date_envoi    DateTime? @default(now()) @db.Timestamp(6)
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model alertes_departement {
  id              Int               @id @default(autoincrement())
  departement     String            @db.VarChar(50)
  niveau_alerte   String            @db.VarChar(30)
  message         String
  consignes       String?
  date_debut      DateTime          @db.Timestamp(6)
  date_fin        DateTime?         @db.Timestamp(6)
  est_automatique Boolean?          @default(false)
  declenchee_par  Int?
  date_creation   DateTime?         @default(now()) @db.Timestamp(6)
  autorites       autorites?        @relation(fields: [declenchee_par], references: [id], onDelete: NoAction, onUpdate: NoAction)
  historiques_sms historiques_sms[]
  rapports_crise  rapports_crise[]
  sinistres       sinistres[]

  @@index([date_debut, date_fin], map: "idx_alertes_dates")
  @@index([departement], map: "idx_alertes_departement")
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model autorites {
  id                  Int                   @id @default(autoincrement())
  email               String                @unique @db.VarChar(100)
  mot_de_passe        String                @db.VarChar(255)
  nom                 String                @db.VarChar(100)
  prenom              String?               @db.VarChar(100)
  service             String                @db.VarChar(50)
  departement         String?               @db.VarChar(50)
  telephone           String?               @db.VarChar(20)
  date_creation       DateTime?             @default(now()) @db.Timestamp(6)
  actif               Boolean?              @default(true)
  alertes_departement alertes_departement[]
  rapports_crise      rapports_crise[]

  @@index([email], map: "idx_autorites_email")
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model citoyens {
  id               Int            @id @default(autoincrement())
  telephone        String         @unique @db.VarChar(20)
  email            String         @unique
  mot_de_passe     String         @db.VarChar(255)
  nom              String         @db.VarChar(100)
  prenom           String?        @db.VarChar(100)
  commune          String?        @db.VarChar(50)
  date_inscription DateTime?      @default(now()) @db.Timestamp(6)
  actif            Boolean?       @default(true)
  signalements     signalements[]

  @@index([telephone], map: "idx_citoyens_telephone")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model consignes_securite {
  id              Int       @id @default(autoincrement())
  niveau_alerte   String    @db.VarChar(30)
  langue          String?   @default("francais") @db.VarChar(10)
  titre           String    @db.VarChar(200)
  contenu         String
  ordre_affichage Int?      @default(0)
  date_creation   DateTime? @default(now()) @db.Timestamp(6)
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model donnees_hydrologiques {
  id           Int      @id @default(autoincrement())
  cours_eau    String   @db.VarChar(100)
  niveau_eau   Decimal? @db.Decimal(10, 2)
  debit        Decimal? @db.Decimal(10, 2)
  seuil_alerte Decimal? @db.Decimal(10, 2)
  statut       String?  @db.VarChar(20)
  date_mesure  DateTime @db.Timestamp(6)
  source       String?  @db.VarChar(100)
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model donnees_meteo {
  id               Int           @id @default(autoincrement())
  zone_id          Int?
  temperature      Decimal?      @db.Decimal(5, 2)
  humidite         Int?
  precipitation    Decimal?      @db.Decimal(5, 2)
  risque_pluie     Int?
  date_observation DateTime      @db.Timestamp(6)
  date_creation    DateTime?     @default(now()) @db.Timestamp(6)
  zones_risque     zones_risque? @relation(fields: [zone_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model historique_inondations {
  id                       Int       @id @default(autoincrement())
  annee                    Int
  zones_touchees           String?
  departements             String?
  nombre_victimes          Int?      @default(0)
  nombre_maisons_detruites Int?      @default(0)
  hectares_submerges       Decimal?  @default(0) @db.Decimal(10, 2)
  description              String?
  source                   String?   @db.VarChar(100)
  image_url                String?
  date_creation            DateTime? @default(now()) @db.Timestamp(6)
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model historiques_sms {
  id                  Int                  @id @default(autoincrement())
  alerte_id           Int?
  message             String
  destinataires       Int?
  statut              String?              @default("envoye") @db.VarChar(20)
  date_envoi          DateTime?            @default(now()) @db.Timestamp(6)
  alertes_departement alertes_departement? @relation(fields: [alerte_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model photos_signalement {
  id             Int           @id @default(autoincrement())
  signalement_id Int?
  url_photo      String
  date_upload    DateTime?     @default(now()) @db.Timestamp(6)
  signalements   signalements? @relation(fields: [signalement_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model points_evacuation {
  id              Int       @id @default(autoincrement())
  nom             String    @db.VarChar(100)
  type            String?   @db.VarChar(30)
  capacite_max    Int?      @default(0)
  taux_occupation Int?      @default(0)
  latitude        Decimal   @db.Decimal(10, 8)
  longitude       Decimal   @db.Decimal(11, 8)
