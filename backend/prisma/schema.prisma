/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model signalements {
  id                 Int                  @id @default(autoincrement())
  citoyen_id         Int?
  latitude           Decimal              @db.Decimal(10, 8)
  longitude          Decimal              @db.Decimal(11, 8)
  niveau_eau         String               @db.VarChar(30)
  description        String?
  lieu               String?              @db.VarChar(255)
  photo_url          String?
  statut             String?              @default("en_attente") @db.VarChar(20)
  zone_risque_id     Int?
  date_creation      DateTime?            @default(now()) @db.Timestamp(6)
  date_traitement    DateTime?            @db.Timestamp(6)
  photos_signalement photos_signalement[]
  citoyens           citoyens?            @relation(fields: [citoyen_id], references: [id], onUpdate: NoAction)
  zones_risque       zones_risque?        @relation(fields: [zone_risque_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([citoyen_id], map: "idx_signalements_citoyen")
  @@index([latitude, longitude], map: "idx_signalements_coords")
  @@index([date_creation(sort: Desc)], map: "idx_signalements_date")
}

