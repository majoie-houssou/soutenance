  id                  Int                  @id @default(autoincrement())
  alerte_id           Int?
  nom_famille         String               @db.VarChar(100)
  nombre_personnes    Int
  besoins             String?
  latitude            Decimal?             @db.Decimal(10, 8)
  longitude           Decimal?             @db.Decimal(11, 8)
  telephone           String?              @db.VarChar(20)
  heberge_dans        String?              @db.VarChar(100)
  statut              String?              @default("en_attente") @db.VarChar(20)
  date_enregistrement DateTime?            @default(now()) @db.Timestamp(6)
  alertes_departement alertes_departement? @relation(fields: [alerte_id], references: [id], onUpdate: NoAction)
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model spatial_ref_sys {
  srid      Int     @id
  auth_name String? @db.VarChar(256)
